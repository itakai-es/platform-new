# Backend API URL
NUXT_PUBLIC_API_BASE=http://localhost:3001

# Set to 'true' to use real backend instead of MSW mocks
# When false or not set, MSW mocks will intercept API requests
NUXT_PUBLIC_USE_REAL_BACKEND=true

# Show demo login buttons on the login page
NUXT_PUBLIC_SHOW_DEMO_BUTTONS=true

# Google OAuth Configuration
# Get this from Google Cloud Console > Credentials
NUXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
