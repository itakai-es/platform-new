# ==========================================
# ITAKAI API - Environment variables example
# ==========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.

# ---- Database ----
DATABASE_URL=postgresql://itakai:CHANGE_ME@localhost:5432/itakai_dev

# ---- Server ----
PORT=3001
NODE_ENV=development

# ---- CORS (comma-separated origins) ----
CORS_ORIGIN=http://localhost:4000

# ---- Auth - JWT ----
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Cifrado de secretos de configuración ----
# Cifra las API keys / claves de R2 que se guardan desde el panel de admin.
# Genera con: openssl rand -base64 32
# Si no se define, se deriva de JWT_ACCESS_SECRET (suficiente para dev).
SETTINGS_ENCRYPTION_KEY=

# ---- Auth - Google OAuth ----
GOOGLE_CLIENT_ID=your.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_secret

# =====================================================================
# A partir de aquí, TODO es opcional: son DEFAULTS de arranque. Lo normal
# en auto-hospedaje es dejarlo vacío y configurarlo desde el panel de
# administración (Configuración → IA / Almacenamiento / Dominio / General),
# que lo guarda cifrado en la base de datos y tiene prioridad sobre el .env.
# =====================================================================

# ---- AI - Endpoint de texto/imágenes por defecto (compatible con OpenAI: Spark, vLLM, OpenAI…) ----
# Es solo el default de arranque; el endpoint real (texto e imágenes) se configura
# desde el panel de administración. SPARK_ROUTER_* alimenta ambos por defecto.
SPARK_ROUTER_BASE_URL=http://localhost:8000
SPARK_ROUTER_API_KEY=your_spark_router_key
SPARK_ROUTER_MODEL=your_spark_router_text_model
SPARK_ROUTER_IMAGE_MODEL=your_spark_router_image_model

# ---- AI - Fallback providers ----
GOOGLE_API_KEY=your_google_api_key
GEMINI_TEXT_MODEL=your_gemini_text_model
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_IMAGE_MODEL=your_openrouter_image_model

# ---- AI - Rate limiting ----
AI_RATE_LIMIT_PER_HOUR=60

# ---- Email (Resend) ----
# Leave empty to skip email sending in dev
RESEND_API_KEY=your_resend_key
RESEND_FROM=noreply@example.com
EMAIL_FROM=ITAKAI <noreply@example.com>

# ---- Almacenamiento (default: disco local; editable desde el panel) ----
# STORAGE_DRIVER=local|s3
# Para Cloudflare R2 / S3 (STORAGE_DRIVER=s3):
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.tu-dominio.com   # URL pública del bucket
# S3_FORCE_PATH_STYLE=true

# ---- Dominio y generales (editables desde el panel) ----
# APP_URL=https://tu-dominio.com      # usado en los enlaces de los emails
# PLATFORM_NAME=ITAKAI
# CONTACT_EMAIL=
# DEFAULT_LANGUAGE=es
# REGISTRATION_OPEN=true
# MAINTENANCE_MODE=false
