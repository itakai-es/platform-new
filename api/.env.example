# ==========================================
# ITAKAI API - Environment variables example
# ==========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.

# ---- Database ----
DATABASE_URL=postgresql://itakai:CHANGE_ME@localhost:5432/itakai_dev

# ---- Server ----
PORT=3001
NODE_ENV=development

# ---- CORS (comma-separated origins) ----
CORS_ORIGIN=http://localhost:4000

# ---- Auth - JWT ----
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Auth - Google OAuth ----
GOOGLE_CLIENT_ID=your.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_secret

# ---- AI - Spark Router (primary provider) ----
SPARK_ROUTER_BASE_URL=http://localhost:8000
SPARK_ROUTER_API_KEY=your_spark_router_key
SPARK_ROUTER_MODEL=your_spark_router_text_model
SPARK_ROUTER_IMAGE_MODEL=your_spark_router_image_model

# ---- AI - Fallback providers ----
GOOGLE_API_KEY=your_google_api_key
GEMINI_TEXT_MODEL=your_gemini_text_model
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_IMAGE_MODEL=your_openrouter_image_model

# ---- AI - Rate limiting ----
AI_RATE_LIMIT_PER_HOUR=60

# ---- Email (Resend) ----
# Leave empty to skip email sending in dev
RESEND_API_KEY=your_resend_key
RESEND_FROM=noreply@example.com
EMAIL_FROM=ITAKAI <noreply@example.com>
