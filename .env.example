# =======================================
# ITAKAI - Environment Variables
# =======================================

# ---------------------------------------
# PostgreSQL Database
# ---------------------------------------
POSTGRES_USER=itakai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=itakai_prod

# ---------------------------------------
# Backend API
# ---------------------------------------
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://itakai:change-me-in-production@postgres:5432/itakai_prod

# JWT Authentication
JWT_ACCESS_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# AI - Spark Router (preferred)
# Requires VPN access to the Spark private network
SPARK_ROUTER_BASE_URL=http://localhost:8000
SPARK_ROUTER_API_KEY=local-testing-key
SPARK_ROUTER_MODEL=google/gemma-4-26b-a4b-it
SPARK_ROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b

# Optional legacy fallback providers
GOOGLE_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-flex

# ---------------------------------------
# Frontend App
# ---------------------------------------
NUXT_PUBLIC_API_BASE=https://api.itakai.es
# For development: http://localhost:3001

# ---------------------------------------
# Production Notes
# ---------------------------------------
# 1. Copy this file to /api/.env.prod and /app/.env
# 2. Generate secure JWT secrets:
#    openssl rand -base64 32
# 3. Never commit .env files to git
# 4. Use strong passwords for PostgreSQL in production
