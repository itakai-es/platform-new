# =============================================================================
# ITAKAI · overrides OPCIONALES para el auto-hospedaje.
#
# NO necesitas este fichero para arrancar: `docker compose up` funciona con
# defaults (BD itakai/itakai, http://localhost, almacenamiento local, secretos
# autogenerados y admin creado con la contraseña impresa en los logs).
#
# Copia a `.env.selfhost` y descomenta SOLO lo que quieras cambiar; luego añade
# `--env-file .env.selfhost` al `docker compose ... up`.
# =============================================================================

# ── Admin inicial (si no pones contraseña, se genera y sale en los logs) ──
# ADMIN_EMAIL=admin@tu-dominio.com
# ADMIN_PASSWORD=una_contraseña_fuerte

# ── Tu dominio (como el "site URL" de WordPress) ──
#   SERVER_NAME  → el dominio con el que responde nginx (sin http://)
#   CORS_ORIGIN / APP_URL → la URL completa (con http:// o https://)
# SERVER_NAME=itakai.miinstituto.es
# CORS_ORIGIN=https://itakai.miinstituto.es
# APP_URL=https://itakai.miinstituto.es

# ── Puerto HTTP de nginx (por defecto 80) ──
# HTTP_PORT=8080

# ── Cookies: si sirves por HTTPS, ponlas seguras ──
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax

# ── Base de datos (por defecto itakai/itakai) ──
# POSTGRES_USER=itakai
# POSTGRES_PASSWORD=una_contraseña_fuerte
# POSTGRES_DB=itakai

# ── (Opcional) Login con Google ──
# NUXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── (Opcional) Email transaccional (Resend) ──
# RESEND_API_KEY=
# EMAIL_FROM=ITAKAI <noreply@tu-dominio.com>

# ── (Avanzado) Secretos: se autogeneran y persisten; defínelos solo si quieres
#    fijarlos tú (p. ej. para compartirlos entre réplicas) ──
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# SETTINGS_ENCRYPTION_KEY=
