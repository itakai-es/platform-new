# =============================================================================
# ITAKAI · variables de ARRANQUE (bootstrap) para el despliegue auto-hosteable.
# Copia este fichero a `.env.selfhost` y rellena los valores.
#
# Esto es SOLO lo mínimo para arrancar. El resto de la configuración
# (proveedores de IA, generación de imágenes, almacenamiento R2, dominio y
# parámetros generales) se hace desde el panel de administración una vez
# levantado, sin tocar ficheros.
# =============================================================================

# ── Base de datos ──
POSTGRES_USER=itakai
POSTGRES_PASSWORD=CAMBIA_ESTO
POSTGRES_DB=itakai

# ── Puerto HTTP público de nginx ──
HTTP_PORT=80

# ── Administrador inicial (para `pnpm db:bootstrap`) ──
ADMIN_EMAIL=admin@tu-dominio.com
ADMIN_PASSWORD=CAMBIA_ESTO_una_contraseña_fuerte

# ── Secretos JWT (genera cada uno con: openssl rand -base64 48) ──
JWT_ACCESS_SECRET=CAMBIA_ESTO_openssl_rand_base64_48
JWT_REFRESH_SECRET=CAMBIA_ESTO_openssl_rand_base64_48

# ── Clave de cifrado de los secretos guardados desde el panel (API keys, R2…) ──
# Genera con: openssl rand -base64 32
# IMPORTANTE: si la cambias, habrá que reintroducir los secretos desde el panel.
SETTINGS_ENCRYPTION_KEY=CAMBIA_ESTO_openssl_rand_base64_32

# ── Dominio inicial (orígenes CORS permitidos, separados por comas) ──
# También editable después desde el panel → Configuración → Dominio.
CORS_ORIGIN=https://tu-dominio.com
# URL pública de la instancia (para los enlaces de los emails). Opcional aquí;
# se puede fijar desde el panel.
APP_URL=https://tu-dominio.com

# ── Cookies de sesión ──
# Este stack sirve por HTTP (puerto 80). Para que el login persista sobre HTTP:
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
# ⚠️ Para una instancia accesible desde internet, usa HTTPS (TLS delante) y pon
#    COOKIE_SECURE=true. Servir auth por HTTP plano solo es aceptable en red interna.

# ── (Opcional) Login con Google ──
NUXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── (Opcional) Email transaccional (Resend) ──
RESEND_API_KEY=
EMAIL_FROM=ITAKAI <noreply@tu-dominio.com>
